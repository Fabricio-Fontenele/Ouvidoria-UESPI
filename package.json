{
  "name": "ouvidoria-backend-core",
  "version": "1.0.0",
  "description": "Backend core for the Institutional Ombudsman System",
  "type": "module",
  "imports": {
    "#src/*.js": {
      "development": "./src/*.ts",
      "default": "./build/*.js"
    }
  },
  "scripts": {
    "clean": "rimraf ./build ./.cache",
    "build": "pnpm clean && tsc -p ./tsconfig.build.json",
    "dev": "tsx watch --env-file=.env src/main/server.ts",
    "start": "node --env-file=.env build/main/server.js",
    "type:check": "tsc --noEmit --project ./tsconfig.test.json",
    "type:check:ts7": "tsc --noEmit --project ./tsconfig.test.json --stableTypeOrdering",
    "lint": "eslint . --cache",
    "lint:ci": "eslint . --cache --max-warnings=0",
    "lint-staged": "lint-staged",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run --passWithNoTests",
    "test:ci": "vitest run --coverage",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:e2e": "vitest run --config ./vitest.config.e2e.mjs",
    "test:e2e:watch": "vitest --config ./vitest.config.e2e.mjs",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:seed": "prisma db seed",
    "prisma:format": "prisma format",
    "prisma:validate": "prisma validate",
    "check": "pnpm format:check && pnpm lint && pnpm type:check && pnpm test",
    "check:ci": "pnpm format:check && pnpm lint:ci && pnpm type:check && pnpm test:ci",
    "prepare": "husky",
    "postinstall": "prisma generate"
  },
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "keywords": [],
  "author": "Eyder Rios",
  "license": "MIT",
  "engines": {
    "node": ">=22 <23"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/eslint-plugin": "^1.6.15",
    "eslint": "^9",
    "eslint-config-prettier": "^9",
    "eslint-import-resolver-typescript": "^3",
    "eslint-plugin-import": "^2",
    "eslint-plugin-n": "^17",
    "eslint-plugin-promise": "^7",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^15",
    "prettier": "^3",
    "prisma": "^7.8.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.0",
    "vitest-mock-extended": "^4.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/supabase-js": "^2.105.4",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "file-type": "^22.0.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "zod": "^4.4.3"
  }
}
