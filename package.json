{
  "name": "ts-project",
  "version": "1.0.0",
  "description": "TypeScript project template with ESLint, Prettier, Vitest and Husky",
  "type": "module",
  "imports": {
    "#src/*.js": {
      "development": "./src/*.ts",
      "default": "./build/*.js"
    }
  },
  "scripts": {
    "dev": "NODE_OPTIONS='--conditions=development' tsx ./src/main.ts",
    "start": "node ./build/main.js",
    "clean": "rimraf ./build ./.cache",
    "build": "pnpm clean && tsc -p ./tsconfig.build.json",
    "type:check": "tsc --noEmit --project ./tsconfig.test.json",
    "type:check:ts7": "tsc --noEmit --project ./tsconfig.test.json --stableTypeOrdering",
    "lint": "eslint . --cache",
    "lint:ci": "eslint . --cache --max-warnings=0",
    "lint-staged": "lint-staged",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run --passWithNoTests",
    "test:ci": "vitest run --coverage",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "check": "pnpm format:check && pnpm lint && pnpm type:check && pnpm test",
    "check:ci": "pnpm format:check && pnpm lint:ci && pnpm type:check && pnpm test:ci",
    "prepare": "husky"
  },
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "keywords": [],
  "author": "Eyder Rios",
  "license": "MIT",
  "engines": {
    "node": ">=22 <23"
  },
  "dependencies": {
    "dotenv": "^16"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/eslint-plugin": "^1.6.15",
    "eslint": "^9",
    "eslint-config-prettier": "^9",
    "eslint-import-resolver-typescript": "^3",
    "eslint-plugin-import": "^2",
    "eslint-plugin-n": "^17",
    "eslint-plugin-promise": "^7",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^15",
    "prettier": "^3",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.0",
    "vitest-mock-extended": "^4.0.0"
  }
}
