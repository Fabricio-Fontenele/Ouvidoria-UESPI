# Prisma / persistence
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ouvidoria?schema=public"

# HTTP server
HOST="0.0.0.0"
PORT="3333"

# Auth
JWT_SECRET="change-me-with-a-strong-32+-char-secret"
JWT_EXPIRES_IN_SECONDS="28800"

# Cryptography
PASSWORD_HASH_ROUNDS="10"

# Supabase Storage
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="manifestation-attachments"
SUPABASE_SIGNED_URL_EXPIRES_IN_SECONDS="300"

# Email
# - "console" (default): prints messages in backend logs.
# - "brevo": sends real transactional emails through Brevo's REST API.
EMAIL_PROVIDER="console"
# BREVO_API_KEY="xkeysib-your-api-key"
# EMAIL_FROM="verified-sender@example.com"
EMAIL_FROM_NAME="Ouvidoria UESPI"

# AI gateway
# - "fake" (default): uses the in-process FakeAiGateway, no external service needed.
# - "http": calls @ouvidoria/ai-api via HTTP. Requires AI_SERVICE_BASE_URL and AI_SERVICE_API_KEY.
AI_GATEWAY_PROVIDER="fake"
# AI_SERVICE_BASE_URL="http://localhost:4000"
# AI_SERVICE_API_KEY="change-me"
AI_SERVICE_TIMEOUT_MS="30000"
# AI_HISTORY_MAX_CHARS="12000"
# CATALOG_CACHE_TTL_MS="300000"

# Docker Compose only — not read by the app itself.
# These feed docker-compose variable interpolation; without them compose warns
# "variable is not set. Defaulting to a blank string" and the backend container
# gets a blank DB password (auth fails on `prisma migrate deploy`).
# POSTGRES_PASSWORD must match the password in DATABASE_URL above.
POSTGRES_PASSWORD="postgres"
# ai-postgres (pgVector) password. Leave blank: its volume is initialized without a
# password and ai-api connects with an empty one. A non-empty value breaks ai-api auth.
AI_POSTGRES_PASSWORD=

# Frontend build only — not read by the backend app.
# scripts/deploy.sh reads this and bakes it into the web bundle at build time
# (Vite exposes VITE_-prefixed vars). In prod the front and API share the same
# origin (Caddy proxies /me, /sessions, etc. to 127.0.0.1:3333), so point it at
# the public site origin. For local dev set it in web/.env instead.
VITE_API_BASE_URL="https://ouvidoria.fabriciofontenele.com.br"
