# Prisma / persistence
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ouvidoria?schema=public"

# HTTP server
HOST="0.0.0.0"
PORT="3333"

# Auth
JWT_SECRET="change-me-with-a-strong-32+-char-secret"
JWT_EXPIRES_IN_SECONDS="28800"

# Cryptography
PASSWORD_HASH_ROUNDS="10"

# Supabase Storage
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="manifestation-attachments"
SUPABASE_SIGNED_URL_EXPIRES_IN_SECONDS="300"
