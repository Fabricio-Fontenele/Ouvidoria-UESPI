{
  "name": "@ouvidoria/ai-api",
  "version": "0.1.0",
  "description": "AI microservice for the UESPI Ombudsman System: RAG over institutional documents + structured manifestation drafting via Gemini.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/main/server.js",
    "dev": "tsx watch src/main/server.ts",
    "ingest": "tsx src/infra/ingestion/ingest-knowledge-base.ts",
    "ingest:reset": "tsx src/infra/ingestion/ingest-knowledge-base.ts --reset",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type:check": "tsc --noEmit",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres"
  },
  "devDependencies": {
    "@types/node": "^24.3.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.15.5",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.1",
    "@langchain/community": "^1.1.4",
    "@langchain/core": "^1.1.13",
    "@langchain/google-genai": "^2.1.30",
    "@langchain/textsplitters": "^1.0.1",
    "dotenv": "^16.6.1",
    "fastify": "^5.2.1",
    "langchain": "^1.2.8",
    "pdf-parse": "^1.1.1",
    "pg": "^8.16.3",
    "zod": "^4.4.3"
  }
}
