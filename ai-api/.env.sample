# HTTP server
HOST="0.0.0.0"
PORT="4000"

# Google AI Studio API Key (obtain at https://aistudio.google.com/apikey)
GOOGLE_API_KEY="your_google_api_key_here"

# Embeddings
GOOGLE_EMBEDDING_MODEL="models/gemini-embedding-001"
GOOGLE_EMBEDDING_DIMS="3072"

# Chat / generation. Must support structured output (Gemini 1.5+, Gemini 3.x).
# Confirm what your key has access to with:
#   curl -s "https://generativelanguage.googleapis.com/v1beta/models?key=$GOOGLE_API_KEY"
GOOGLE_CHAT_MODEL="models/gemini-3-flash"
LLM_TEMPERATURE="0.1"

# pgVector (the local docker-compose maps Postgres to host port 5433)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/rag"
PG_VECTOR_COLLECTION_NAME="ouvidoria_kb"

# Knowledge base
KB_DIR="./docs/knowledge-base"

# RAG tuning. Bump chunk size for long institutional docs (regiment, etc.).
RAG_CHUNK_SIZE="400"
RAG_CHUNK_OVERLAP="0"
RAG_TOP_K="4"

# Shared secret with the main backend. Must match AI_SERVICE_API_KEY there.
AI_API_KEY="change-me"

# Request hardening
REQUEST_BODY_LIMIT_BYTES="65536"
