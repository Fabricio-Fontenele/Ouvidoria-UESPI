# HTTP server
HOST="0.0.0.0"
PORT="4000"

# Google AI Studio API Key (obtain at https://aistudio.google.com/apikey)
GOOGLE_API_KEY="your_google_api_key_here"

# Embeddings
GOOGLE_EMBEDDING_MODEL="models/gemini-embedding-001"
GOOGLE_EMBEDDING_DIMS="3072"

# Chat / generation. Must support structured output (Gemini 1.5+, Gemini 3.x).
# Confirm what your key has access to with:
#   curl -s "https://generativelanguage.googleapis.com/v1beta/models?key=$GOOGLE_API_KEY"
GOOGLE_CHAT_MODEL="models/gemini-2.5-flash"
LLM_TEMPERATURE="0.1"

# pgVector (the local docker-compose maps Postgres to host port 5433)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/rag"
PG_VECTOR_COLLECTION_NAME="ouvidoria_kb"

# Knowledge base
KB_DIR="./docs/knowledge-base"

# RAG tuning. Bump chunk size for long institutional docs (regiment, etc.).
# RAG_TOP_K is the number of chunks pulled per query. Normative questions
# ("Qual o prazo do Art. 15?") need broader recall to land the right paragraph;
# the final LLM call filters irrelevant chunks. 8 is a safe baseline — raise
# further if recall is still weak, but watch latency and prompt budget.
# RAG_CHUNK_OVERLAP keeps the parent article header attached to the chunk
# carrying the §. With overlap=0 the splitter cuts between "#### Art. 15" and
# "§ 1º ... trinta dias", so the LLM never sees which article the § belongs to
# and hallucinates the number. 300 chars is enough to carry the previous
# heading across.
RAG_CHUNK_SIZE="400"
RAG_CHUNK_OVERLAP="300"
RAG_TOP_K="8"

# Ingestion: batch size sent to the embedding provider per request, plus how
# many extra retries to attempt per item that comes back empty (dim=0). These
# defaults are tuned for the Gemini free tier, where larger batches silently
# drop items. With a paid tier or a more permissive provider you can safely
# raise BATCH_SIZE (e.g. 20) and lower MAX_RETRIES (e.g. 3) to speed ingestion.
RAG_EMBEDDING_BATCH_SIZE="5"
RAG_EMBEDDING_MAX_RETRIES="6"

# Shared secret with the main backend. Must match AI_SERVICE_API_KEY there.
AI_API_KEY="change-me"

# Request hardening
REQUEST_BODY_LIMIT_BYTES="65536"
