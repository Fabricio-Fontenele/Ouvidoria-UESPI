generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  manifestant
  ombudsman
  admin

  @@map("user_role")
}

enum ManifestationType {
  report
  complaint
  suggestion
  compliment

  @@map("manifestation_type")
}

enum ManifestationStatus {
  in_analysis
  answered
  canceled
  finalized

  @@map("manifestation_status")
}

enum ManifestationMessageSenderType {
  manifestant
  anonymous_manifestant
  ombudsman
  admin
  system

  @@map("manifestation_message_sender_type")
}

enum ManifestationAttachmentUploadedByType {
  MANIFESTANT
  ANONYMOUS_MANIFESTANT
  OMBUDSMAN
  ADMIN

  @@map("manifestation_attachment_uploaded_by_type")
}

model User {
  id                     String                    @id @default(uuid()) @db.Uuid
  name                   String
  email                  String                    @unique
  passwordHash           String                    @map("password_hash")
  role                   UserRole
  createdAt              DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  authoredManifestations Manifestation[]           @relation("ManifestationAuthor")
  attendedManifestations Manifestation[]           @relation("ManifestationAttendant")
  sentMessages           ManifestationMessage[]
  evaluationsAsAttendant ManifestationEvaluation[] @relation("EvaluationAttendant")
  evaluationsAsAuthor    ManifestationEvaluation[] @relation("EvaluationAuthor")
  uploadedAttachments    ManifestationAttachment[]

  @@index([role])
  @@map("users")
}

model Campus {
  id                  String               @id
  name                String
  city                String?
  isActive            Boolean              @default(true) @map("is_active")
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  administrativeUnits AdministrativeUnit[]

  @@index([isActive])
  @@map("campuses")
}

model AdministrativeUnit {
  id          String   @id
  name        String
  description String?
  campusId    String   @map("campus_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  campus      Campus   @relation(fields: [campusId], references: [id])

  @@index([campusId])
  @@index([isActive])
  @@index([campusId, isActive])
  @@map("administrative_units")
}

model Manifestation {
  id                   String                    @id @default(uuid()) @db.Uuid
  protocol             String                    @unique
  type                 ManifestationType
  status               ManifestationStatus       @default(in_analysis)
  campusId             String                    @map("campus_id")
  administrativeUnitId String                    @map("administrative_unit_id")
  description          String                    @db.Text
  involvedPeople       String?                   @map("involved_people") @db.Text
  authorUserId         String?                   @map("author_user_id") @db.Uuid
  attendantUserId      String?                   @map("attendant_user_id") @db.Uuid
  accessCodeHash       String?                   @map("access_code_hash")
  createdAt            DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  author               User?                     @relation("ManifestationAuthor", fields: [authorUserId], references: [id])
  attendant            User?                     @relation("ManifestationAttendant", fields: [attendantUserId], references: [id])
  messages             ManifestationMessage[]
  evaluation           ManifestationEvaluation?
  attachments          ManifestationAttachment[]

  @@index([authorUserId])
  @@index([attendantUserId])
  @@index([status])
  @@index([type])
  @@index([campusId])
  @@index([administrativeUnitId])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([campusId, administrativeUnitId])
  @@index([status, campusId, administrativeUnitId, createdAt])
  @@map("manifestations")
}

model ManifestationEvaluation {
  id                    String        @id @default(uuid()) @db.Uuid
  manifestationId       String        @unique @map("manifestation_id") @db.Uuid
  attendantUserId       String        @map("attendant_user_id") @db.Uuid
  attendantRoleSnapshot UserRole      @map("attendant_role_snapshot")
  authorUserId          String        @map("author_user_id") @db.Uuid
  rating                Int
  comment               String?       @db.Text
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  manifestation         Manifestation @relation(fields: [manifestationId], references: [id])
  attendant             User          @relation("EvaluationAttendant", fields: [attendantUserId], references: [id])
  author                User          @relation("EvaluationAuthor", fields: [authorUserId], references: [id])

  @@index([attendantUserId])
  @@index([authorUserId])
  @@map("manifestation_evaluations")
}

model ManifestationMessage {
  id              String                         @id @default(uuid()) @db.Uuid
  manifestationId String                         @map("manifestation_id") @db.Uuid
  senderUserId    String?                        @map("sender_user_id") @db.Uuid
  senderType      ManifestationMessageSenderType @map("sender_type")
  content         String                         @db.Text
  createdAt       DateTime                       @default(now()) @map("created_at") @db.Timestamptz(6)
  manifestation   Manifestation                  @relation(fields: [manifestationId], references: [id])
  senderUser      User?                          @relation(fields: [senderUserId], references: [id])

  @@index([manifestationId, createdAt])
  @@index([senderUserId])
  @@map("manifestation_messages")
}

model ManifestationAttachment {
  id               String                                @id @default(uuid()) @db.Uuid
  manifestationId  String                                @map("manifestation_id") @db.Uuid
  storageKey       String                                @unique @map("storage_key")
  originalName     String                                @map("original_name")
  mimeType         String                                @map("mime_type")
  sizeInBytes      Int                                   @map("size_in_bytes")
  uploadedByType   ManifestationAttachmentUploadedByType @map("uploaded_by_type")
  uploadedByUserId String?                               @map("uploaded_by_user_id") @db.Uuid
  createdAt        DateTime                              @default(now()) @map("created_at") @db.Timestamptz(6)
  manifestation    Manifestation                         @relation(fields: [manifestationId], references: [id])
  uploadedByUser   User?                                 @relation(fields: [uploadedByUserId], references: [id])

  @@index([manifestationId, createdAt])
  @@index([uploadedByUserId])
  @@map("manifestation_attachments")
}
